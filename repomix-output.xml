function createItem(name, method, path, body = null) {
  const item = {
    name,
    request: {
      method,
      header: [],
      url: {
        raw: `${baseUrl}${path}`,
        host: ["{{baseUrl}}"],
        path: path.split("/").filter(Boolean)

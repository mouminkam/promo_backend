      message: 'string',
      meta: 'optional pagination { page, limit, total, totalPages }',
    },
  },
  modules: modules.map((m) => ({
    module: m.module,
    count: m.endpoints.length,
    endpoints: m.endpoints.map(enrichEndpoint),
  })),
  flatEndpoints: modules.flatMap((m) =>
    m.endpoints.map((ep) => ({ module: m.module, ...enrichEndpoint(ep) }))
  ),
};

const outDir = path.join(__dirname, '..', 'docs');

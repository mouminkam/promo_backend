  max: 10,
  standardHeaders: true,
  legacyHeaders: false,
  message: {
    success: false,
    data: null,
    message: 'Too many authentication attempts, please try again later',
    error: { code: 'RATE_LIMIT_EXCEEDED' },
  },
});

/**

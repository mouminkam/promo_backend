{
  "name": "promo_backend",
  "version": "1.0.0",
  "description": "Promoo Backend API — Digital platform connecting companies, influencers, service providers, and users",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:api": "newman run promoo_postman_collection.json -r cli,htmlextra --reporter-htmlextra-export ./docs/api-reports/report.html",
    "api:scan": "tsx scripts/run_api_scan.ts",
    "api:reference": "tsx scripts/generate_api_reference.ts",
    "postman:generate": "tsx scripts/generate_postman.ts"
  },
  "keywords": [
    "promoo",
    "api",
    "express",
    "supabase"
  ],
  "author": "Promoo Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.0.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.2.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "express-list-endpoints": "^7.1.1",
    "jest": "^30.4.2",
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.1",
    "nodemon": "^3.1.14",
    "supabase": "^2.107.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
